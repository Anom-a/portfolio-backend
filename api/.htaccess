Options -Indexes

<IfModule mod_setenvif.c>
    SetEnvIf Authorization "(.+)" HTTP_AUTHORIZATION=$1
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Never expose application internals directly.
    RewriteRule ^(src|config|logs|migrations)(/|$) - [F,L]
    RewriteRule ^(\.env|composer\.(json|lock)|\.gitignore)$ - [F,L]

    # Let existing files and folders be served normally.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Route API requests through the front controller.
    RewriteRule ^ index.php [QSA,L]
</IfModule>
